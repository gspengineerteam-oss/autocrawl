# Gluetun overlay configuration. Copy to .env.gluetun and source before
# bringing up the stack with `-f docker-compose.gluetun.yml`.

# === Master toggle ===
# These two are picked up by the crawler app itself; setting them in the
# overlay file is what makes the search modules + Chromium honor the proxy.
VPN_ENABLED=true
PROXY_URL=http://gluetun:8888

# After this many consecutive proxy errors, every outbound httpx call raises
# ProxyDeadError instead of silently falling back to the host IP. This is
# the deanonymization safeguard — leave it unless you understand the risk.
PROXY_MAX_CONSECUTIVE_FAILURES=3

# === Gluetun upstream config ===
# Provider list: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
# Recommended (no-logs, paid w/ crypto):
#   - mullvad        (WireGuard or OpenVPN, easy CLI signup)
#   - protonvpn      (WireGuard or OpenVPN, free tier available)
#   - surfshark      (OpenVPN-only via gluetun)
VPN_PROVIDER=mullvad
VPN_TYPE=wireguard

# WireGuard creds (skip if VPN_TYPE=openvpn). Generate via your provider's
# config download portal then paste the values from the .conf file here.
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# OpenVPN creds (skip if VPN_TYPE=wireguard).
OPENVPN_USER=
OPENVPN_PASSWORD=

# Comma-separated countries to rotate exits across. The first reachable
# server is picked on each reconnect, so listing several = organic IP
# variation. Pick countries close to your search-target regions:
#   - Asia coverage:    Japan,Singapore,Hong Kong
#   - Europe coverage:  Germany,Netherlands,France
#   - Americas:         USA,Canada
VPN_COUNTRIES=Japan,Germany,Netherlands

# Health-probe target Gluetun pings to confirm the tunnel is up. Default
# (cloudflare.com:443) is fine; switch only if your provider blocks it.
VPN_HEALTH_TARGET=cloudflare.com:443
