# =====================================================================
# AutoCrawler API keys (semua opsional, default pakai Groq + Ollama lokal)
# =====================================================================
# Default LLM_PROVIDER=groq. Isi GROQ_API_KEY dari https://console.groq.com.
# Free tier sekitar 14400 request per hari, OpenAI compatible.
GROQ_API_KEY=

# Optional. Cuma dipakai kalau LLM_PROVIDER=openai (escape hatch).
OPENAI_API_KEY=

# Optional. Default ENABLE_FIRECRAWL=false.
FIRECRAWL_API_KEY=

# =====================================================================
# Search providers (semua opsional, semua FREE atau self-hosted)
# =====================================================================
# Tier 2 self-hosted meta-search SearXNG, default ON via compose service.
ENABLE_SEARXNG=true
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=please-change-me-32-chars-minimum-secret-key

# Tier 3 free-tier API dengan key opsional (default OFF, isi key untuk aktifkan).
ENABLE_TAVILY=false
TAVILY_API_KEY=
ENABLE_BRAVE=false
BRAVE_API_KEY=
ENABLE_BING=false
BING_API_KEY=

# Tier 4 niche public API tanpa auth, default ON.
ENABLE_REDDIT=true
REDDIT_SUBREDDITS=MilitaryHardware,cybersecurity,LessCredibleDefence,geopolitics,defense,LawEnforcement
ENABLE_HACKERNEWS=true
ENABLE_GITHUB_SEARCH=true
GITHUB_TOKEN=
ENABLE_ARXIV=true
ENABLE_OPENALEX=true
ENABLE_SEMANTIC_SCHOLAR=true
ENABLE_INTERNET_ARCHIVE=true
ENABLE_WAYBACK_CDX=true

# Plus
ENABLE_JINA_READER=true
JINA_READER_URL=https://r.jina.ai
# Paid Jina key bypasses the 20 req/min free-tier ceiling and unlocks higher-quality extraction.
JINA_API_KEY=
ENABLE_DIRECTORY_SCRAPE=true

# Recon untuk vendor enrichment.
ENABLE_CRTSH=true
ENABLE_URLSCAN=false
URLSCAN_API_KEY=

# =====================================================================
# Self-hosted services (default values match docker-compose.yml)
# =====================================================================
REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chroma
CHROMA_PORT=8000
FLARESOLVERR_URL=http://flaresolverr:8191/v1

# Langfuse (self-hosted LLM tracing — optional, runs in docker-compose)
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENABLED=true

# =====================================================================
# Runtime configuration
# =====================================================================
CRAWL_MODE=normal               # dev | normal | aggressive
RUN_INTERVAL_MINUTES=30
MAX_VENDORS_PER_RUN=200
MAX_EXPOS_PER_RUN=20
LOG_LEVEL=INFO
DATA_DIR=/app/data
LOG_DIR=/app/logs
CONFIG_DIR=/app/config

# =====================================================================
# Concurrency caps (sub-agent parallelism)
# =====================================================================
EXPO_DISCOVERY_CONCURRENCY=10
EXHIBITOR_EXTRACTION_CONCURRENCY=15
VENDOR_RESOLUTION_CONCURRENCY=30
ENRICHMENT_CONCURRENCY=50
BROWSER_POOL_SIZE=20
BROWSER_RECYCLE_AFTER=50

# =====================================================================
# LLM provider
# =====================================================================
# `ollama` (default) → http://ollama:11434 (free, unlimited, lokal)
# `groq`             → Groq cloud, free tier (cek model yang lo punya akses)
# `openai`           → cloud, billed (escape hatch)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
GROQ_BASE_URL=https://api.groq.com/openai/v1

EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://ollama:11434

# Model default untuk Ollama (Granite 4.1 chat plus granite-embedding 278m).
OPENAI_MODEL_HEAVY=granite4.1:3b
OPENAI_MODEL_LIGHT=granite4.1:3b
OPENAI_EMBEDDING_MODEL=granite-embedding:278m

# Switch to OpenAI cloud:
#   LLM_PROVIDER=openai
#   EMBEDDING_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL_HEAVY=gpt-4o
#   OPENAI_MODEL_LIGHT=gpt-4o-mini
#   OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# Switch to fully local Ollama:
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://ollama:11434
#   OPENAI_MODEL_HEAVY=granite4.1:3b
#   OPENAI_MODEL_LIGHT=granite4.1:3b
# (Embedding sudah default Ollama, gak perlu diubah)

# =====================================================================
# Rate limits & politeness
# =====================================================================
PER_DOMAIN_RPS=1.0
GLOBAL_REQUEST_TIMEOUT_SECONDS=60
FIRECRAWL_CREDIT_THRESHOLD_PCT=10   # below this %, fall back to Playwright

# =====================================================================
# Phase 2 trigger
# =====================================================================
PHASE_2_VENDOR_THRESHOLD=100

# =====================================================================
# Database (Postgres for vendor/expo/run storage; FastAPI reads from this)
# =====================================================================
DATABASE_URL=postgresql+asyncpg://postgres:123@autocrawl-db:5432/autocrawl
SQLALCHEMY_ECHO=false
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8090

# =====================================================================
# Translation (vendor data → Bahasa Indonesia)
# =====================================================================
# `nllb`    → NLLB-200 distilled 600M via CTranslate2 (int8, ~1.2GB, CPU)
# `openai`  → fallback ke gpt-4o-mini (billed)
# `none`    → simpan original English saja
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=nllb
NLLB_MODEL_PATH=/app/data/nllb_ct2
NLLB_TOKENIZER_PATH=/app/data/nllb_hf
TARGET_LANGUAGE=id
TRANSLATION_BATCH_SIZE=8
TRANSLATION_MAX_CHARS=2000

# =====================================================================
# PDF brochure extraction
# =====================================================================
PDF_DISCOVERY_ENABLED=true
OCR_ENABLED=true
# OCR for scanned PDFs uses Ollama's vision model — no extra Python/PyTorch
# deps. Page is rendered by PyMuPDF and POSTed to {LLM_BASE_URL}/api/chat.
OCR_VLM_MODEL=gemma4:e4b
OCR_RENDER_DPI=200                 # 150-250 sweet spot for legibility vs payload size
OCR_PAGE_TIMEOUT=60                # seconds per page round-trip to Ollama
PDF_EXTRACTION_CONCURRENCY=4
MAX_PDFS_PER_EXPO=10               # cap to avoid one expo flooding
PDF_MAX_SIZE_MB=50                 # skip larger files
